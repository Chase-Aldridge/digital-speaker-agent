# Copy to .env and fill in. The app runs fully without these (AI falls back to a
# smart template generator, payments run in mock mode) so you can demo offline.

# Secret used to sign auth tokens. Change this in production.
JWT_SECRET=change-me-to-a-long-random-string

# Port the API/server listens on.
PORT=3001

# --- Optional: live AI application generation ---
# When set, the "Generate application" feature calls Claude for tailored copy.
# Without it, a deterministic template generator is used instead.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# --- Optional: Stripe (billing is mocked in the MVP if these are absent) ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
